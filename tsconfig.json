{
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "gi://Gio*": ["./node_modules/@girs/gio-2.0"],
      "gi://GObject*": ["./node_modules/@girs/gobject-2.0"],
      "gi://GLib*": ["./node_modules/@girs/glib-2.0"],
      "gi://St*": ["./node_modules/@girs/st-18"],
      "gi://*": ["./node_modules/@girs/*"],
      "resource://*": ["./node_modules/@girs/gnome-shell/*"],
      "@girs/gobject-2.0": ["./node_modules/@girs/gobject-2.0"],
      "@girs/gio-2.0": ["./node_modules/@girs/gio-2.0"]
    }
  },
  "allowArbitraryExtensions": true,
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["dist", "node_modules"]
}
